<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<VBox prefHeight="650.0" prefWidth="900.0" spacing="0" styleClass="root-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.EmailDigestController">
    <!-- Header Banner -->
    <VBox styleClass="header-banner">
        <padding>
            <Insets top="25.0" right="30.0" bottom="25.0" left="30.0" />
        </padding>
        <Label text="Gmail AI Digest Agent" styleClass="header-title" />
        <Label text="Summarize and prioritize your day using Google Gemini AI" styleClass="header-subtitle" />
    </VBox>

    <!-- Main Content Area -->
    <VBox spacing="20.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="25.0" right="30.0" bottom="25.0" left="30.0" />
        </padding>

        <!-- Action Control Bar -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="control-bar">
            <padding>
                <Insets top="15.0" right="20.0" bottom="15.0" left="20.0" />
            </padding>
            <Button fx:id="generateDigestButton" onAction="#onGenerateDigestButtonClick" text="Generate Daily Digest" styleClass="primary-button" />
            <ProgressIndicator fx:id="progressIndicator" visible="false" prefWidth="24.0" prefHeight="24.0" styleClass="custom-progress" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
                <Label text="STATUS" styleClass="status-title-label" />
                <Label fx:id="statusLabel" text="System ready" styleClass="status-value-label" />
            </VBox>
        </HBox>

        <!-- Summary View Card -->
        <VBox styleClass="card-pane" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
            </padding>
            <Label text="Actionable Digest" styleClass="card-title" />
            <TextArea fx:id="summaryTextArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" styleClass="summary-text-area" />
        </VBox>
    </VBox>
</VBox>
